<?xml version='1.0' encoding='utf-8'?>
<widget id="pt.nos.osatmospheretest" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>YourAppName</name>
    <description>Your app description</description>
    <author email="dev@cordova.apache.org" href="http://cordova.io">Your Name</author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    <platform name="android">
        <allow-intent href="market:*" />
        <preference name="APP_DOMAIN_HOST" value="outsystemsdevdmz.corporativo.pt" />
        <preference name="APP_DOMAIN_PATH" value="/OSTESTAPP/" />
        <preference name="ASSET_LINKS_PATH" value="/OSTESTAPP/.well-known/assetlinks.json" />
    </platform>
    <plugin name="cordova-plugin-deeplinks" spec="https://github.com/MiguelRosaDev/cordova-deeplinks-plugin" />
</widget>

